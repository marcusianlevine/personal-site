---
interface Props {
	name: string;
	location: string;
	photo: string;
}

const { name, location, photo } = Astro.props;
---

<div class="testimonial">
	<blockquote>
		<div class="testimonial-header">
			<img src={photo} alt={name} class="testimonial-photo" />
		</div>
		<div class="testimonial-content">
			<slot />
			&nbsp;
			<p class="signature">— {name}, {location}</p>
		</div>
	</blockquote>
</div>

<style>
	.testimonial {
		margin: 2rem 0;
	}

	blockquote {
		font-size: var(--text-base);
		font-family: var(--font-body);
		font-weight: 400;
		line-height: 1.5;
		padding: 1.5rem;
		border: 0.25rem solid var(--accent-dark);
		border-radius: 20px;
		color: var(--gray-0);
		margin: 0;
	}

	.testimonial-header {
		display: flex;
		justify-content: center;
		margin-bottom: 1.5rem;
	}

	.testimonial-photo {
		width: 80px;
		height: 120px;
		border-radius: 50%;
		object-fit: cover;
		border: 0.25rem solid var(--accent-dark);
	}

	.testimonial-content {
		text-align: center;
	}

	.testimonial-content p {
		margin: 0.5rem 0;
	}

	.signature {
		margin-top: 1.5rem;
		font-style: italic;
	}

	@media (min-width: 50em) {
		blockquote {
			display: flex;
			gap: 2rem;
			align-items: flex-start;
			text-align: left;
		}

		.testimonial-header {
			margin-bottom: 0;
			flex-shrink: 0;
		}

		.testimonial-photo {
			width: 100px;
			height: 140px;
		}

		.testimonial-content {
			flex: 1;
			text-align: left;
		}
	}
</style>
